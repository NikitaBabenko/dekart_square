@using DecisionHelper.Core.Localization
@using DecisionHelper.Web.Auth
@using DecisionHelper.Web.Endpoints
@using Microsoft.Extensions.Options
@inject ICurrentUserAccessor CurrentUser
@inject IStringResolver T
@inject IHttpContextAccessor Http
@inject IOptions<AppOptions> AppOpts

@{
    var locale = CurrentUser.Locale;
    var title = T[Strings.AppTitle, locale];
    var description = T[Strings.SeoDescription, locale];
    var ogAlt = T[Strings.SeoOgImageAlt, locale];
    var baseUrl = Http.HttpContext is { } ctx ? SeoEndpoints.ResolveBaseUrl(ctx, AppOpts.Value) : AppOpts.Value.AppBaseUrl.TrimEnd('/');
    var path = Http.HttpContext?.Request.Path.Value ?? "/";
    var canonical = $"{baseUrl}{path}";
    var ogImage = $"{baseUrl}/og-image.png";
}

<!DOCTYPE html>
<html lang="@locale" dir="@(SupportedLocales.Rtl.Contains(locale) ? "rtl" : "ltr")">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@description" />
    <link rel="canonical" href="@canonical" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@canonical" />
    <meta property="og:title" content="@title" />
    <meta property="og:description" content="@description" />
    <meta property="og:image" content="@ogImage" />
    <meta property="og:image:alt" content="@ogAlt" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@title" />
    <meta name="twitter:description" content="@description" />
    <meta name="twitter:image" content="@ogImage" />
    <base href="/" />
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["DecisionHelper.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body class="bg-zinc-50 text-zinc-900 antialiased">
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script src="js/tma.js"></script>
</body>

</html>
