@page "/"
@using DecisionHelper.Core.Localization
@using DecisionHelper.Web.Auth
@inject ICurrentUserAccessor CurrentUser
@inject IStringResolver T

<PageTitle>@T[Strings.AppTitle, CurrentUser.Locale]</PageTitle>

<section class="py-10">
    <h1 class="text-3xl font-bold tracking-tight text-zinc-900 mb-3">
        @T[Strings.AppTitle, CurrentUser.Locale]
    </h1>
    <p class="text-zinc-600 mb-6">@T[Strings.AppTagline, CurrentUser.Locale]</p>

    <a href="/app"
       class="inline-block bg-zinc-900 text-white px-5 py-2 rounded-md hover:bg-zinc-800">
        @T[Strings.CtaTry, CurrentUser.Locale]
    </a>
</section>

<section class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-8">
    <div class="border border-zinc-200 rounded-lg p-4 bg-white">
        <h3 class="font-semibold text-sm text-emerald-700 mb-2">@T[Strings.Q1Title, CurrentUser.Locale]</h3>
        <p class="text-sm text-zinc-600">Pros of doing</p>
    </div>
    <div class="border border-zinc-200 rounded-lg p-4 bg-white">
        <h3 class="font-semibold text-sm text-rose-700 mb-2">@T[Strings.Q2Title, CurrentUser.Locale]</h3>
        <p class="text-sm text-zinc-600">Cons of doing</p>
    </div>
    <div class="border border-zinc-200 rounded-lg p-4 bg-white">
        <h3 class="font-semibold text-sm text-emerald-700 mb-2">@T[Strings.Q3Title, CurrentUser.Locale]</h3>
        <p class="text-sm text-zinc-600">Pros of not doing</p>
    </div>
    <div class="border border-zinc-200 rounded-lg p-4 bg-white">
        <h3 class="font-semibold text-sm text-rose-700 mb-2">@T[Strings.Q4Title, CurrentUser.Locale]</h3>
        <p class="text-sm text-zinc-600">Cons of not doing</p>
    </div>
</section>
