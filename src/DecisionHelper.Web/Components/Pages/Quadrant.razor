@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public IReadOnlyList<string> Items { get; set; } = Array.Empty<string>();
    [Parameter] public string Tone { get; set; } = "zinc";
}

<div class="border border-zinc-200 rounded-lg p-4 bg-white">
    <h3 class="font-semibold text-sm mb-2 text-@Tone-700">@Title</h3>
    @if (Items.Count == 0)
    {
        <p class="text-sm text-zinc-400">—</p>
    }
    else
    {
        <ul class="space-y-1 list-disc pl-5">
            @foreach (var item in Items)
            {
                <li class="text-sm text-zinc-700">@item</li>
            }
        </ul>
    }
</div>
