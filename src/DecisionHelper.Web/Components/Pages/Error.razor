@page "/Error"
@using System.Diagnostics
@using DecisionHelper.Core.Localization
@using DecisionHelper.Web.Auth
@inject ICurrentUserAccessor CurrentUser
@inject IStringResolver T

<PageTitle>@T[Strings.ErrorTitle, CurrentUser.Locale]</PageTitle>

<section class="py-16 max-w-md mx-auto text-center">
    <h1 class="text-2xl font-bold mb-3">@T[Strings.ErrorTitle, CurrentUser.Locale]</h1>
    <p class="text-zinc-600 mb-6">@T[Strings.ErrorBody, CurrentUser.Locale]</p>
    <a href="/" class="inline-block bg-zinc-900 text-white px-5 py-2 rounded-md hover:bg-zinc-800">
        @T[Strings.ErrorCtaHome, CurrentUser.Locale]
    </a>
    @if (ShowRequestId)
    {
        <p class="mt-6 text-xs text-zinc-400">
            <code>@RequestId</code>
        </p>
    }
</section>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
